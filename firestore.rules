rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES & HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isTimestamp(val) {
      return val is timestamp || (val is string && val.size() <= 128);
    }

    function isAdmin() {
      // For this app, we define admin by email. 
      // Hardcoded for robustness as per user's current project state.
      return isSignedIn() && (
        request.auth.token.email == 'admin@orientationbf.com' || 
        request.auth.token.email == 'urbain.traoreurb@gmail.com' ||
        request.auth.token.email == 'urbain.traore@gmail.com' ||
        request.auth.token.email == 'urbain.traore.dev@gmail.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- VALIDATION BLUEPRINTS ---

    function isValidUserProfile(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.profileType in ['student', 'parent', 'teacher', 'etablissement', 'system_admin']
        && data.createdAt is string
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 256))
        && (!('fcmToken' in data) || (data.fcmToken is string && data.fcmToken.size() <= 1024))
        && (!('photoUrl' in data) || data.photoUrl is string)
        && (!('level' in data) || data.level is string)
        && (!('school' in data) || data.school is string)
        && (!('institutionName' in data) || data.institutionName is string)
        && (!('institutionType' in data) || data.institutionType is string)
        && (!('description' in data) || data.description is string)
        && (!('childName' in data) || data.childName is string)
        && (!('childLevel' in data) || data.childLevel is string)
        && (!('hasPaid' in data) || data.hasPaid is bool)
        && (!('loginEnabled' in data) || data.loginEnabled is bool)
        && (!('date' in data) || data.date is string)
        && (!('age' in data) || data.age is number)
        && (!('trimesters' in data) || data.trimesters is list)
        && (!('bepc' in data) || data.bepc is map)
        && (!('bac' in data) || data.bac is map)
        && (!('analysisResult' in data) || data.analysisResult is map);
    }

    function isValidScholarship(data) {
      return data.title is string && data.title.size() <= 256
        && data.country is string && data.country.size() <= 128
        && data.organization is string && data.organization.size() <= 256
        && data.degreeLevel is string
        && data.deadline is string
        && data.applicationUrl is string && data.applicationUrl.size() <= 2048
        && data.officialSource is string && data.officialSource.size() <= 2048
        && isTimestamp(data.createdAt);
    }

    function isValidInstitution(data) {
      return data.name is string && data.name.size() <= 256
        && data.type is string
        && data.description is string && data.description.size() <= 10000
        && data.city is string
        && data.country is string
        && data.website is string
        && (!('ownerId' in data) || (data.ownerId is string && data.ownerId.size() <= 128))
        && (!('createdAt' in data) || isTimestamp(data.createdAt));
    }

    function isValidUFR(data) {
      return data.institutionId is string && data.institutionId.size() <= 128
        && data.name is string && data.name.size() <= 256
        && isTimestamp(data.createdAt);
    }

    function isValidProgram(data) {
      return data.institutionId is string && data.institutionId.size() <= 128
        && data.name is string && data.name.size() <= 512
        && isTimestamp(data.createdAt);
    }

    function isValidPost(data) {
      return data.establishmentId is string && data.establishmentId.size() <= 128
        && data.title is string && data.title.size() <= 256
        && data.content is string && data.content.size() <= 10000
        && isTimestamp(data.createdAt);
    }

    function isValidSavedProject(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.type in ['bepc', 'bac']
        && data.name is string && data.name.size() <= 256
        && data.date is string
        && data.profile is map
        && data.result is map;
    }

    function isValidFormation(data) {
      return data.titre is string && data.titre.size() <= 256
        && data.description is string && data.description.size() <= 10000
        && data.domaine is string && data.domaine.size() <= 128
        && data.niveau in ['Débutant', 'Intermédiaire', 'Avancé']
        && data.type in ['Présentiel', 'En ligne', 'Hybride']
        && data.duree is string && data.duree.size() <= 128
        && (!('prix' in data) || data.prix is number)
        && data.lieu is string && data.lieu.size() <= 256
        && data.date_debut is string
        && data.date_fin is string
        && data.image is string && data.image.size() <= 1024
        && data.createur_id is string && data.createur_id.size() <= 128
        && data.createur_type in ['admin', 'etablissement']
        && data.statut in ['brouillon', 'publie', 'archive']
        && data.date_creation is string;
    }

    function isValidMarketplaceListing(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 256
        && data.description is string && data.description.size() > 0 && data.description.size() <= 5000
        && data.price is number && data.price >= 0
        && data.category in ['Livres scolaires & universitaires', 'Matériel didactique', 'Vélos & Motos', 'Vie étudiante & Autres']
        && data.condition in ['Neuf', 'Très bon état', 'Bon état', 'État satisfaisant']
        && data.images is list && data.images.size() <= 4
        && data.location is string && data.location.size() <= 256
        && data.contact is string && data.contact.size() <= 128
        && data.createdAt is string
        && data.status in ['active', 'sold', 'reported', 'deleted']
        && (!('reportsCount' in data) || data.reportsCount is number)
        && (!('reportedBy' in data) || data.reportedBy is list);
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().uid == userId
        && (incoming().profileType != 'system_admin' || isAdmin()); // Prevent self-promoting to admin unless actually admin
        
      allow update: if (isOwner(userId) || isAdmin())
        && isValidUserProfile(incoming())
        && incoming().uid == existing().uid
        && (isAdmin() || (incoming().profileType == existing().profileType && incoming().createdAt == existing().createdAt));
        
      allow delete: if isAdmin();
    }

    match /scholarships/{scholarshipId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidScholarship(incoming());
    }

    match /institutions/{institutionId} {
      allow read: if true;
      allow create: if (isAdmin() || (isSignedIn() && incoming().ownerId == request.auth.uid))
        && isValidInstitution(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid))
        && isValidInstitution(incoming())
        && (isAdmin() || incoming().ownerId == existing().ownerId);
      allow delete: if isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid);
    }

    match /ufrs/{ufrId} {
      allow read: if true;
      allow create: if (isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/institutions/$(incoming().institutionId)).data.ownerId == request.auth.uid))
        && isValidUFR(incoming());
      allow update: if (isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/institutions/$(existing().institutionId)).data.ownerId == request.auth.uid))
        && isValidUFR(incoming());
      allow delete: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/institutions/$(existing().institutionId)).data.ownerId == request.auth.uid);
    }

    match /programs/{programId} {
      allow read: if true;
      allow create: if (isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/institutions/$(incoming().institutionId)).data.ownerId == request.auth.uid))
        && isValidProgram(incoming());
      allow update: if (isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/institutions/$(existing().institutionId)).data.ownerId == request.auth.uid))
        && isValidProgram(incoming());
      allow delete: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/institutions/$(existing().institutionId)).data.ownerId == request.auth.uid);
    }

    match /establishment_posts/{postId} {
      allow read: if true;
      allow create: if (isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/institutions/$(incoming().establishmentId)).data.ownerId == request.auth.uid))
        && isValidPost(incoming());
      allow update: if (isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/institutions/$(existing().establishmentId)).data.ownerId == request.auth.uid))
        && isValidPost(incoming());
      allow delete: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/institutions/$(existing().establishmentId)).data.ownerId == request.auth.uid);
    }

    match /saved_projects/{projectId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && isValidSavedProject(incoming());
        
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && isValidSavedProject(incoming());
        
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /government_opportunities/{opportunityId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /useful_links/{linkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /career_competitions/{competitionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /employment_trends/{trendId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Notifications often need specialized access
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /formations/{formationId} {
      allow get: if true;
      allow list: if resource.data.statut == 'publie' || (isSignedIn() && (resource.data.createur_id == request.auth.uid || isAdmin()));

      allow create: if (
        isAdmin() && isValidFormation(incoming()) && incoming().createur_id == request.auth.uid && incoming().createur_type == 'admin'
      ) || (
        isSignedIn() 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profileType == 'etablissement'
        && isValidFormation(incoming())
        && incoming().createur_id == request.auth.uid
        && incoming().createur_type == 'etablissement'
        && incoming().statut == 'brouillon'
      );

      allow update: if isValidFormation(incoming()) && (
        (isAdmin() && incoming().createur_type == existing().createur_type && incoming().createur_id == existing().createur_id) || (
          isSignedIn()
          && existing().createur_id == request.auth.uid
          && incoming().createur_id == existing().createur_id
          && incoming().createur_type == existing().createur_type
          && (existing().statut == 'brouillon' ? (incoming().statut in ['brouillon', 'archive']) : (incoming().statut == existing().statut))
        )
      );

      allow delete: if isAdmin() || (isSignedIn() && existing().createur_id == request.auth.uid);
    }

    match /marketplace_listings/{listingId} {
      allow get: if true;
      allow list: if resource.data.status == 'active' || (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()));

      allow create: if isSignedIn()
        && incoming().userId == request.auth.uid
        && isValidMarketplaceListing(incoming());

      allow update: if isSignedIn() && (
        // Case 1: Owner updates their listing
        (existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidMarketplaceListing(incoming())) ||
        // Case 2: Any signed in user can report a listing (only affects reportsCount, reportedBy, or status)
        (incoming().diff(existing()).affectedKeys().hasOnly(['reportsCount', 'reportedBy', 'status']) && incoming().reportsCount == existing().reportsCount + 1 && (incoming().status == 'reported' || incoming().status == existing().status)) ||
        // Case 3: Admin updates anything
        isAdmin()
      );

      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }
  }
}
